# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.venv/
venv/

# Node
node_modules/

# Local env / secrets
.env
.env.*
!.env.example
source-config.json

# Build outputs
dist/
build/

# Runtime data
data/raw/**
!data/raw/.gitkeep
data/public/**
!data/public/.gitkeep
data/normalized/**
!data/normalized/.gitkeep
data/*.sqlite3
data/enrichment_cache.sqlite3

# Reports / logs
reports/**
!reports/.gitkeep
logs/**
!logs/.gitkeep
*.traceback.txt

# Generic caches / temp
cache/
*.tmp
tmp/
output/

# Playwright local browser cache (downloaded by `playwright install`)
.playwright-cli/
.playwright/

# Crawler bundle local artifacts (only source code under includes/ should be tracked)
includes/**/.venv/
includes/**/venv/
includes/**/__pycache__/
includes/**/*.pyc
includes/**/logs/
includes/**/reports/
includes/**/output/
includes/**/.playwright-cli/
includes/**/TEST_RESULTS.txt

# Local AI tooling (per-machine)
.claude/
.agents/
.codex/
